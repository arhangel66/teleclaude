# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated list of Telegram chat IDs allowed to talk to the bot
ALLOWED_CHAT_IDS=123456789,987654321

# Working directory where the Claude subprocess runs
# On server: /opt/telegram-bridge/workspace
WORKING_DIRECTORY=/home/user/projects

# Path to the claude CLI binary
# On server: /usr/bin/claude (check with `which claude`)
CLAUDE_BINARY=claude

# Path to SQLite DB storing chat -> claude session mapping
# Relative paths resolve against systemd WorkingDirectory
SQLITE_DB=sessions.db
