# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram chat IDs allowed to talk to the bot.
# Find yours via @userinfobot.
ALLOWED_CHAT_IDS=123456789

# Working directory where the selected CLI subprocess runs.
# This is the repo/folder the agent will operate on.
WORKING_DIRECTORY=./workspace

# CLI backend: claude (default) or codex.
AGENT_BACKEND=claude

# Path to the claude CLI binary (check with `which claude`).
CLAUDE_BINARY=claude

# Path to the codex CLI binary (check with `which codex`).
CODEX_BINARY=codex

# SQLite DB storing (chat_id, backend) -> CLI session mapping.
SQLITE_DB=sessions.db

# OpenRouter API key for voice transcription (Gemini Flash).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug for speech-to-text. Default is Gemini 2.5 Flash (cheap, multilingual).
STT_MODEL=google/gemini-3-flash-preview

# Streaming UX mode:
#   thread  — one edited-in-place log message (blockquote) + one final-answer message (default)
#   verbose — each assistant text/tool/thinking block is a separate Telegram message
#   compact — single progress message is edited, then deleted on final
#   quiet   — only the final answer is sent
STREAMING_MODE=thread

# Days to keep downloaded attachments in files/ before cleanup.
FILE_RETENTION_DAYS=7
